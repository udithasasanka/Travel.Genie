                </div>
                
                <div class="activity-card">
                    <div style="font-size: 2.5rem; margin-bottom: 15px;">🌺</div>
                    <h4 style="margin: 15px 0;">Temple & Ritual</h4>
                    <p style="font-size: 0.95rem;">Participate in Buddhist ceremonies and temple rituals with monks</p>
                </div>
            </div>
        </section>

