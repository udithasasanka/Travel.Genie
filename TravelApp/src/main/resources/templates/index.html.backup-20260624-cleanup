        <!-- Trust Badges Section -->
        <section class="trust-badges-section">
            <p style="color: #607d8b; margin-bottom: 30px; font-weight: 600;">Trusted by Thousands • Award-Winning Service</p>
            
            <div class="badges-grid">
                <div class="badge-item">
                    <div class="badge-icon">✓</div>
                    <p>Sri Lanka Tourism Board Certified</p>
                </div>
                
                <div class="badge-item">
                    <div class="badge-icon">🏆</div>
                    <p>Best Travel Agency 2025</p>
                </div>
                
                <div class="badge-item">
                    <div class="badge-icon">🔒</div>
                    <p>100% Secure Booking</p>
                </div>
                
                <div class="badge-item">
                    <div class="badge-icon">🌍</div>
                    <p>ISO 9001 Certified</p>
                </div>
            </div>
        </section>
        <section class="stats-section">
            <div class="stats-grid-home">
                <div class="stat-item">
                    <h3>50+</h3>
                    <p>Destinations</p>
                </div>
                <div class="stat-item">
                    <h3>100+</h3>
                    <p>Travel Packages</p>
                </div>
                <div class="stat-item">
                    <h3>10,000+</h3>
                    <p>Happy Travelers</p>
                </div>
                <div class="stat-item">
                    <h3>4.9★</h3>
                    <p>Average Rating</p>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="cta-section">
            <h2>Ready for Your Next Adventure?</h2>
            <p>Join thousands of travelers discovering amazing destinations with TravelApp</p>
            <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
                <button class="btn-primary" style="background: #1abc9c; color: white;" onclick="window.location.href='/packages'">Browse Packages</button>
                <button class="btn-secondary" style="background: #1abc9c; color: white; border: none;" onclick="window.location.href='/destinations'">Discover Destinations</button>
            </div>
        </section>
    </div>
</main>
<footer class="site-footer">
    <div class="container">
        <p>© 2026 TravelApp. All Rights Reserved.</p>
    </div>
</footer>
