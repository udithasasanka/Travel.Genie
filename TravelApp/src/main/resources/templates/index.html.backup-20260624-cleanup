                <div class="testimonial-card">
                    <p style="color: #ffa500; font-weight: bold; margin-bottom: 15px;">⭐⭐⭐⭐⭐ 5/5</p>
                    <p style="font-style: italic; color: #607d8b; line-height: 1.8;">"The attention to detail was amazing. Every moment was perfectly planned. Highly recommend!"</p>
                    <p style="font-weight: 600; color: #263238; margin-top: 15px;">- Marco Rossi, Italy</p>
                </div>
            </div>
        </section>

        <!-- Newsletter Signup Section -->
        <section class="newsletter-section">
            <h2>✉️ Get Exclusive Sri Lanka Travel Tips</h2>
            <p>Receive insider guides, hidden gems, and special offers to your inbox!</p>
            
            <div class="newsletter-form">
                <input type="email" placeholder="Enter your email" required>
                <button>Subscribe</button>
            </div>
