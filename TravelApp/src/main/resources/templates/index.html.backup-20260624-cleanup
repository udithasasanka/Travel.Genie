<body>
<header class="site-header">
    <div class="container header-inner">
               <h1><a th:href="@{/}">🌍 TravelApp</a></h1>
        <nav>
            <a th:href="@{/}">Home</a>
            <a th:href="@{/destinations}">Destinations</a>
            <a th:href="@{/packages}">Packages</a>
            <a th:href="@{/about}">About</a>
            <a th:href="@{/contact}">Contact</a>
            <a th:if="${session.userRole == 'ADMIN'}" th:href="@{/admin}">Admin</a>
            <span th:if="${session.user != null}" class="user-info">
                Welcome, <strong th:text="${session.userName}"></strong> 
                (<span th:text="${session.userRole}"></span>) | 
                <a th:href="@{/logout}">Logout</a>
            </span>
            <a th:if="${session.user == null}" th:href="@{/login}">Login</a>
        </nav>
    </div>
</header>

<main>
    <!-- Premium Hero Section - Sri Lanka Theme -->
    <section class="hero-premium">
        <div class="hero-content">
            <h2>🏝️ Discover the Pearl of the Indian Ocean</h2>
            <p>Experience Sri Lanka's pristine beaches, ancient temples, lush tea plantations, and vibrant culture. Your tropical adventure awaits!</p>
            <div class="hero-buttons">
                <button class="btn-primary" onclick="window.location.href='/packages'">Plan Your Journey</button>
                <button class="btn-secondary" onclick="window.location.href='/destinations'">Explore Destinations</button>
            </div>
        </div>
    </section>

    <div class="container">
        <!-- Features Section -->
        <section class="features-section">
            <div class="section-heading">
                <h2>Why Choose TravelApp?</h2>
                <p>Experience travel planning like never before with our premium services and expert recommendations</p>
            </div>
            
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">✈️</div>
                    <h3>Curated Packages</h3>
                    <p>Handpicked travel packages designed by travel experts to ensure the best experiences at amazing prices.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🗺️</div>
                    <h3>Expert Guides</h3>
                    <p>Local expert guides at every destination to show you the hidden gems and cultural highlights.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">💰</div>
                    <h3>Best Prices</h3>
                    <p>Get the best value for your money with our competitive pricing and special deals year-round.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🛡️</div>
                    <h3>100% Safe</h3>
                    <p>Travel with confidence knowing all trips are fully insured and backed by our security guarantee.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">⭐</div>
                    <h3>5-Star Reviews</h3>
                    <p>Join thousands of satisfied travelers who rated TravelApp 5 stars for exceptional service.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">📱</div>
                    <h3>24/7 Support</h3>
                    <p>Our dedicated support team is available round the clock to assist you during your journey.</p>
                </div>
            </div>
        </section>

        <!-- Popular Destinations Section -->
        <section class="destinations-showcase">
            <div class="showcase-header">
                <h2>🏖️ Popular Destinations</h2>
                <a th:href="@{/destinations}">View All →</a>
            </div>
            
            <div class="grid-2">
                <div class="destination-card" th:each="destination : ${destinations}">
                    <img th:src="${destination.imageUrl}" th:alt="${destination.name}"/>
                    <div class="destination-info">
                        <h4 th:text="${destination.name}"></h4>
                        <span class="destination-country" th:text="${destination.country}"></span>
                        <p class="destination-description" th:text="${destination.description}"></p>
                        <p style="color: #667eea; font-weight: 700; margin: 10px 0 0;">$<span th:text="${destination.price}"></span></p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Featured Packages Section -->
        <section class="packages-showcase">
            <div class="showcase-header">
                <h2>✨ Featured Travel Packages</h2>
                <a th:href="@{/packages}">Explore More →</a>
            </div>
            
            <div class="grid-2">
                <div class="package-card" th:each="pkg : ${packages}">
                    <div class="package-image">
                        <img th:src="${pkg.imageUrl}" th:alt="${pkg.name}"/>
                        <div class="price-badge">$<span th:text="${pkg.price}"></span></div>
                    </div>
                    <div class="package-details">
                        <span class="package-category" th:text="${pkg.category}"></span>
                        <h4 th:text="${pkg.name}"></h4>
                        <p class="package-description" th:text="${pkg.description}"></p>
                        <div class="package-footer">
                            <span class="package-rating">⭐ <span th:text="${pkg.rating}"></span></span>
                            <a th:href="@{/packages/{id}(id=${pkg.id})}" class="package-btn">Book Now</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Best Time to Visit Sri Lanka Section -->
        <section style="margin: 80px 0; padding: 60px 40px; background: linear-gradient(135deg, #fff5f0, #fff9e6); border-radius: 20px;">
            <div class="section-heading">
                <h2>📅 Best Time to Visit Sri Lanka</h2>
                <p>Choose your perfect season for the ultimate Sri Lankan experience</p>
            </div>
            
            <div class="grid-2">
                <div class="season-card">
                    <div style="font-size: 3rem; margin-bottom: 15px;">☀️</div>
                    <h3 style="color: #1abc9c; margin: 15px 0;">Dry Season (Dec-Mar)</h3>
                    <p><strong>Best for: West & South Coasts</strong></p>
                    <p>Perfect weather for beach relaxation and water sports. Ideal for Mirissa, Unawatuna, and Arugambe.</p>
                    <span style="display: inline-block; background: #fff3cd; padding: 8px 16px; border-radius: 20px; margin-top: 10px; color: #333;">✓ Highly Recommended</span>
                </div>
                
                <div class="season-card">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🌊</div>
                    <h3 style="color: #1abc9c; margin: 15px 0;">Monsoon Season (May-Sep)</h3>
                    <p><strong>Best for: East Coast & Mountains</strong></p>
                    <p>Green landscapes, fewer crowds, and perfect for tea plantations and hiking adventures.</p>
                    <span style="display: inline-block; background: #e3f2fd; padding: 8px 16px; border-radius: 20px; margin-top: 10px; color: #333;">✓ Budget Friendly</span>
                </div>
                
                <div class="season-card">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🌺</div>
                    <h3 style="color: #1abc9c; margin: 15px 0;">January Festival</h3>
                    <p><strong>Best for: Cultural Events</strong></p>
                    <p>Experience Duruthu Perahera, Negombo festival, and authentic Sri Lankan celebrations.</p>
                    <span style="display: inline-block; background: #f3e5f5; padding: 8px 16px; border-radius: 20px; margin-top: 10px; color: #333;">✓ Cultural Immersion</span>
                </div>
                
                <div class="season-card">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🌴</div>
                    <h3 style="color: #1abc9c; margin: 15px 0;">Year-Round</h3>
                    <p><strong>Best for: All Adventurers</strong></p>
                    <p>Sri Lanka's tropical climate means you can visit anytime. Each season has its own charm!</p>
                    <span style="display: inline-block; background: #e8f5e9; padding: 8px 16px; border-radius: 20px; margin-top: 10px; color: #333;">✓ Always Amazing</span>
                </div>
            </div>
        </section>

        <!-- Authentic Sri Lankan Experiences Section -->
        <section style="margin: 80px 0; background: #f8f9fa; padding: 60px 40px; border-radius: 20px;">
            <div class="section-heading">
                <h2>🌿 Authentic Sri Lankan Experiences</h2>
                <p>Immerse yourself in the real Sri Lanka beyond the tourist trail</p>
            </div>
            
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon" style="background: linear-gradient(135deg, #8b6914, #d4af37);">☕</div>
                    <h3>Tea Plantation Tours</h3>
                    <p>Pick fresh tea leaves on misty Nuwara Eliya slopes, visit factories, and learn centuries-old tradition from local tea makers.</p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon" style="background: linear-gradient(135deg, #d4af37, #c9a961);">🚂</div>
                    <h3>Mountain Train Rides</h3>
                    <p>Ride the legendary colonial train through dramatic highlands, pine forests, and stunning viewpoints with locals.</p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon" style="background: linear-gradient(135deg, #f39c12, #e67e22);">🏰</div>
                    <h3>Ancient Temple Tours</h3>
                    <p>Explore sacred Buddhist temples like Sigiriya, Temple of Tooth, and medieval cave monasteries with expert historians.</p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon" style="background: linear-gradient(135deg, #27ae60, #229954);">🐘</div>
                    <h3>Wildlife Safari</h3>
                    <p>Spot elephants, leopards, and exotic birds in Yala National Park and Udawalawe on thrilling safari adventures.</p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon" style="background: linear-gradient(135deg, #e74c3c, #c0392b);">🎭</div>
                    <h3>Cultural Immersion</h3>
                    <p>Stay with local families, learn traditional cuisine, wear sarongs, and experience genuine Sri Lankan hospitality.</p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon" style="background: linear-gradient(135deg, #3498db, #2980b9);">🌊</div>
                    <h3>Surfing & Water Sports</h3>
                    <p>Catch world-class waves in Arugambe, Mirissa, and Hikkaduwa with professional instructors and beachside camps.</p>
                </div>
            </div>
        </section>

        <!-- Sri Lankan Cuisine Delights Section -->
        <section style="margin: 80px 0; padding: 60px 40px; background: linear-gradient(135deg, #fff3e0, #ffe0b2); border-radius: 20px;">
            <div class="section-heading">
                <h2>🍛 Taste Authentic Sri Lankan Cuisine</h2>
                <p>Indulge in flavors that will make your journey unforgettable</p>
            </div>
            
            <div class="grid-2">
                <div class="cuisine-card">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🥘</div>
                    <h4>Kottu Roti</h4>
                    <p>Chopped roti stir-fried with curry, vegetables, and spices - a street food legend</p>
                </div>
                
                <div class="cuisine-card">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🦐</div>
                    <h4>Deviled Spices</h4>
                    <p>Prawns & vegetables cooked with chili and spices - perfect for seafood lovers</p>
                </div>
                
                <div class="cuisine-card">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🍲</div>
                    <h4>Lamprais</h4>
                    <p>Spiced rice & meat wrapped in banana leaves - a royal delicacy</p>
                </div>
                
                <div class="cuisine-card">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🥥</div>
                    <h4>Wambatu Curry</h4>
                    <p>Eggplant in aromatic coconut curry - vegetarian paradise</p>
                </div>
            </div>
        </section>

        <!-- Must-Do Activities Section -->
        <section style="margin: 80px 0; background: linear-gradient(135deg, #1abc9c, #0e6251); color: white; padding: 60px 40px; border-radius: 20px;">
            <div class="section-heading" style="color: white;">
                <h2>🎯 5 Must-Do Adventures</h2>
                <p style="color: rgba(255,255,255,0.9);">Essential experiences that define a Sri Lankan journey</p>
            </div>
            
            <div class="activities-grid">
                <div class="activity-card">
                    <div style="font-size: 2.5rem; margin-bottom: 15px;">🏔️</div>
                    <h4 style="margin: 15px 0;">Climb Sigiriya Rock</h4>
                    <p style="font-size: 0.95rem;">Hike to the top of this 5th-century rock fortress for panoramic views</p>
                </div>
                
                <div class="activity-card">
                    <div style="font-size: 2.5rem; margin-bottom: 15px;">🌅</div>
                    <h4 style="margin: 15px 0;">Watch Sunrise at Ella</h4>
                    <p style="font-size: 0.95rem;">Trek to Little Adam's Peak for breathtaking sunrise views</p>
                </div>
                
                <div class="activity-card">
                    <div style="font-size: 2.5rem; margin-bottom: 15px;">🏖️</div>
