<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TravelX</title>
    <link rel="stylesheet" th:href="@{/css/styles.css}">
    <style>
        :root {
            --accent: #f39c12;
            --primary: #1abc9c;
            --dark: #0b3f34;
            --surface: #ffffff;
            --surface-soft: #f7faf7;
            --muted: #5f6f7b;
        }
        .site-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(255, 255, 255, 0.94);
            backdrop-filter: blur(12px);
            z-index: 1000;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
        }
        .site-header .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 6%;
        }
        .logo {
            font-weight: 900;
            color: var(--primary);
            font-size: 1.45rem;
            letter-spacing: -0.03em;
        }
        nav a {
            margin-left: 20px;
            color: #163639;
            font-weight: 600;
        }
        nav a:hover {
            color: var(--accent);
        }
        .hero {
            position: relative;
            min-height: 78vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 120px 6% 80px;
            background: linear-gradient(135deg, rgba(16, 70, 50, 0.92), rgba(9, 32, 24, 0.92)), url('/images/hero-bg.svg');
            background-size: cover;
            background-position: center;
            border-radius: 22px;
            overflow: hidden;
            color: white;
        }
        .hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.45));
            pointer-events: none;
        }
        .hero .hero-inner {
            position: relative;
            z-index: 1;
            max-width: 900px;
            text-align: center;
        }
        .hero h1 {
            font-size: clamp(3rem, 6vw, 4.4rem);
            margin-bottom: 20px;
            line-height: 1.03;
        }
        .hero p {
            font-size: 1.05rem;
            margin-bottom: 28px;
            color: rgba(255, 255, 255, 0.94);
            line-height: 1.75;
        }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 14px 28px;
            border-radius: 999px;
            font-weight: 700;
            text-decoration: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .btn:hover {
            transform: translateY(-2px);
        }
        .btn.alt {
            background: rgba(255, 255, 255, 0.16);
            border: 1px solid rgba(255, 255, 255, 0.24);
            color: white;
        }
        .btn {
            background: var(--accent);
            color: #0d2c25;
        }
        .search-row {
            margin-top: 24px;
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }
        .search-row input {
            padding: 14px 18px;
            border-radius: 999px;
            border: none;
            min-width: 320px;
            max-width: 520px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.14);
        }
        .search-row button {
            padding: 14px 18px;
            border-radius: 999px;
            border: none;
            cursor: pointer;
            background: white;
            color: var(--accent);
            font-weight: 700;
            box-shadow: 0 16px 32px rgba(0, 0, 0, 0.12);
        }
        @media (max-width:720px) {
            .hero {
                padding: 90px 5% 56px;
            }
            .hero h1 {
                font-size: 2.5rem;
            }
            .search-row input {
                min-width: 220px;
            }
            nav {
                flex-wrap: wrap;
                justify-content: center;
            }
            .site-header .container {
                gap: 12px;
            }
        }
    </style>
    <script>
        function onSearch(){const q=document.getElementById('q').value; if(q) window.location.href='/destinations?search='+encodeURIComponent(q)}
    </script>
</head>
<body>
<header class="site-header">
    <div class="container">
        <div class="logo">TravelX</div>
        <nav>
            <a th:href="@{/}">Home</a>
            <a th:href="@{/destinations}">Destinations</a>
            <a th:href="@{/packages}">Packages</a>
            <a th:href="@{/blog}">Blog</a>
            <a th:href="@{/contact}">Contact</a>
            <a th:if="${session.user == null}" th:href="@{/login}">Login</a>
            <span th:if="${session.user != null}" style="margin-left:12px">Welcome, <strong th:text="${session.userName}"></strong></span>
        </nav>
    </div>
</header>

<main>
    <section class="hero">
        <div class="hero-inner">
            <p class="eyebrow">Sri Lanka Travel Guide</p>
            <h1>Experience Sri Lanka’s Best Beaches, Temples & Wildlife</h1>
            <p>Discover curated Sri Lanka tours with unforgettable seaside stays, ancient cultural sites, and wildlife safaris.</p>
            <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:16px">
                <a class="btn" th:href="@{/packages}">Book a Package</a>
                <a class="btn alt" th:href="@{/destinations}">View Destinations</a>
            </div>
            <div class="search-row">
                <input id="q" type="text" placeholder="Search Sri Lanka destinations">
                <button onclick="onSearch()">Search</button>
            </div>
        </div>
    </section>

    <section class="section" aria-labelledby="popular-title">
        <h2 id="popular-title" class="section-title">Popular Destinations</h2>
        <div class="cards">
            <div class="card" th:each="d : ${destinations}">
                <img th:src="${d.imageUrl}" th:alt="${d.name}" onerror="this.src='/static/images/dest-bali.svg'"/>
                <div class="card-body">
                    <h3 th:text="${d.name}">Destination</h3>
                    <p th:text="${d.description}">Description</p>
                </div>
            </div>
            <div class="card" th:if="${destinations == null or #lists.isEmpty(destinations)}">
                <img src="/images/dest-bali.svg" alt="Sri Lanka sample"/>
                <div class="card-body"><h3>Sigiriya Rock Fortress</h3><p>Climb the ancient rock palace and enjoy scenic views of lush tea country.</p></div>
            </div>
        </div>
    </section>

    <section class="section" aria-labelledby="why-title">
        <h2 id="why-title" class="section-title">Why Choose Us?</h2>
        <div class="card-grid">
            <div class="card"><div class="card-body"><h3>Curated Packages</h3><p>Handpicked trips crafted by experts.</p></div></div>
            <div class="card"><div class="card-body"><h3>Local Guides</h3><p>Authentic local experiences and knowledge.</p></div></div>
            <div class="card"><div class="card-body"><h3>Best Prices</h3><p>Competitive rates and great value.</p></div></div>
        </div>
    </section>

    <section class="section" aria-labelledby="stats-title">
        <h2 id="stats-title" class="section-title">Why Travelers Love Us</h2>
        <div class="stats-grid">
            <div class="stat-card"><h3>50K+</h3><p>Happy Travelers</p></div>
            <div class="stat-card"><h3>500+</h3><p>Destinations</p></div>
            <div class="stat-card"><h3>15K+</h3><p>Bookings</p></div>
            <div class="stat-card"><h3>24/7</h3><p>Support</p></div>
        </div>
    </section>
</main>

<footer class="site-footer">
    <div class="container">
        <p>© 2026 TravelX. All Rights Reserved.</p>
    </div>
</footer>

</body>
</html>

