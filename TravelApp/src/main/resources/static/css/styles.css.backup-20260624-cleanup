:root {
    --primary: #1abc9c;           /* Tropical Green - Sri Lanka Theme */
    --secondary: #0e6251;         /* Deep Forest Green */
    --accent: #f39c12;            /* Golden Orange */
    --background: #f0f8f6;        /* Light Aqua */
    --surface: #ffffff;
    --text: #263238;
    --muted: #607d8b;
    --radius: 16px;
}

* {
    box-sizing: border-box;
}

body {
    margin: 0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: var(--background);
    color: var(--text);
}

a {
    color: var(--primary);
    text-decoration: none;
}

.site-header {
    background: var(--surface);
    border-bottom: 1px solid #dde3ea;
    padding: 16px 0;
    position: sticky;
    top: 0;
    z-index: 10;
}

.header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

.header-inner h1 {
    margin: 0;
}

.header-inner nav a {
    margin-left: 18px;
    font-weight: 600;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 20px;
}

.hero {
    background: linear-gradient(135deg, rgba(26,188,156,0.95), rgba(14,98,81,0.95));
    color: white;
    border-radius: var(--radius);
    padding: 80px 40px;
    margin: 24px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
}

.hero-copy h2 {
    margin: 0 0 16px;
    font-size: 2.7rem;
}

.hero-copy p {
    margin: 0 0 24px;
    font-size: 1.1rem;
    line-height: 1.7;
}

.button {
    display: inline-block;
    background: var(--primary);
    color: white;
    padding: 12px 24px;
    border-radius: 10px;
    border: none;
    font-weight: 700;
    cursor: pointer;
}

/* Unified button class used in templates */
.btn {
    display: inline-block;
    background: var(--primary);
    color: #000;
    padding: 12px 22px;
    border-radius: 40px;
    font-weight: 700;
    text-decoration: none;
    border: none;
    cursor: pointer;
}

.btn.alt{
    background: transparent;
    color: white;
    border: 2px solid rgba(255,255,255,0.12);
}

.search-row input{
    padding: 12px 16px;
    border-radius: 999px;
    border: none;
    min-width: 260px;
}

.search-row button{
    padding: 12px 18px;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    background: var(--surface);
    color: var(--text);
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
}

.split-grid,
.card-grid,
.stats-grid {
    display: grid;
    gap: 24px;
}

.split-grid {
    grid-template-columns: 1.4fr 1fr;
}

.card-grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
}

.stats-grid {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
}

.card,
.form-card,
.content-card,
.table-card,
.package-detail-card,
.review-card,
.stat-card {
    background: var(--surface);
    border-radius: var(--radius);
    padding: 20px;
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.05);
}

.card img,
.package-detail-card img {
    width: 100%;
    border-radius: var(--radius);
    max-height: 220px;
    object-fit: cover;
}

.card-body h4,
.package-detail-card h3 {
    margin-top: 16px;
}

.page-heading {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
}

.filter-form,
.contact-form,
.booking-form {
    display: grid;
    gap: 12px;
}

.filter-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin: 16px 0;
}

.filter-row a,
.text-button {
    padding: 10px 14px;
    border-radius: 10px;
    background: #e8f0fe;
    color: var(--secondary);
}

input,
textarea,
select {
    width: 100%;
    padding: 12px 14px;
    border-radius: 12px;
    border: 1px solid #d6dbe4;
    font-size: 1rem;
}

textarea {
    min-height: 140px;
    resize: vertical;
}

table {
    width: 100%;
    border-collapse: collapse;
}

thead {
    background: linear-gradient(135deg, rgba(26,188,156,0.9), rgba(14,98,81,0.9)), url('/static/images/hero-bg.svg');
}

th,
td {
    padding: 14px 16px;
    text-align: left;
    border-bottom: 1px solid #e3e9f2;
}


       .site-footer {
           background: linear-gradient(135deg, #2c3e50, #34495e);
           color: white;
           padding: 60px 0 30px;
           margin-top: 40px;
           border-top: 1px solid #dde3ea;
       }
       
       .site-footer h4 {
           color: white;
           margin-bottom: 20px;
           font-weight: 700;
       }
       
       .site-footer p {
           color: rgba(255,255,255,0.8);
           line-height: 1.8;
       }
       
       .site-footer a {
           color: #667eea;
       }
       
       .site-footer a:hover {
           color: #764ba2;
       }
       
       .site-footer ul {
           list-style: none;
           padding: 0;
           margin: 0;
       }
       
       .site-footer ul li {
           margin-bottom: 12px;
       }
       
       .site-footer ul li a {
           color: rgba(255,255,255,0.8);
           text-decoration: none;
           transition: color 0.3s;
       }
       
       .site-footer ul li a:hover {
           color: white;
       }
@media (max-width: 900px) {
    .split-grid {
        grid-template-columns: 1fr;
    }
}
